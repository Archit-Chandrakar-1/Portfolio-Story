rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only the portfolio owner may write.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'archit1chandrakar@gmail.com';
    }

    // ── Public, read-only content (writes are admin-only) ──────────────────
    match /siteConfig/{doc}      { allow read: if true; allow write: if isAdmin(); }
    match /experience/{doc}      { allow read: if true; allow write: if isAdmin(); }
    match /projects/{doc}        { allow read: if true; allow write: if isAdmin(); }
    match /certifications/{doc}  { allow read: if true; allow write: if isAdmin(); }
    match /workflows/{doc}       { allow read: if true; allow write: if isAdmin(); }
    match /services/{doc}        { allow read: if true; allow write: if isAdmin(); }
    match /settings/{doc}        { allow read: if true; allow write: if isAdmin(); }

    // ── Published-gated content ────────────────────────────────────────────
    // Public visitors can read only published docs (the public queries filter
    // on `published == true`); the admin can read everything (drafts included).
    match /clients/{doc} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }
    match /blogs/{doc} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Everything else: deny ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
